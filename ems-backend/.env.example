# ============================================================
# EMS Backend — Production Environment Variables
# Copy this to /opt/ems/backend/.env on the Oracle VM
# Fill in your real values before starting the server!
# ============================================================

# Django Core
# ⚠️ CRITICAL: This MUST be set or Gunicorn will load dev settings (empty database)
DJANGO_SETTINGS_MODULE=ems_core.settings.production
SECRET_KEY=CHANGE_ME_generate_50_char_random_string
DEBUG=False

# Replace YOUR_ORACLE_VM_PUBLIC_IP with your actual Oracle VM public IP address
ALLOWED_HOSTS=YOUR_ORACLE_VM_PUBLIC_IP,YOUR_DOMAIN_HERE

# Database — SQLite (simplest to start, no extra setup)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=/opt/ems/backend/db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# -- OR -- use PostgreSQL (recommended for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=ems
# DB_USER=emsuser
# DB_PASSWORD=CHANGE_ME_strong_password
# DB_HOST=localhost
# DB_PORT=5432
# DB_CONN_MAX_AGE=60

# CORS — Replace with your Oracle VM public IP (and domain if you have one)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://YOUR_ORACLE_VM_PUBLIC_IP
CSRF_TRUSTED_ORIGINS=http://YOUR_ORACLE_VM_PUBLIC_IP

# Celery (optional — comment out if not using background tasks)
CELERY_TASK_ALWAYS_EAGER=True
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Rate Limiting
THROTTLE_USER=300/hour
THROTTLE_ANON=50/hour
PAGE_SIZE=25

# Security
IP_WHITELIST_ENABLED=False
IP_WHITELIST=127.0.0.1,::1
