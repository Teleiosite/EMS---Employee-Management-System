# ============================================================
# HireWix SaaS — Hybrid Cloud Environment Variables
# Use this for both Local Development and OCI Production
# ============================================================

# --- Django Core ---
# DJANGO_SETTINGS_MODULE=ems_core.settings.production (for OCI)
# DJANGO_SETTINGS_MODULE=ems_core.settings.development (for Local)
SECRET_KEY=generate_a_50_char_unique_key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-vm-ip,your-domain.com

# --- Database (Supabase PostgreSQL) ---
# Replace with your Supabase connection details
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DB_HOST=your_project_ref.supabase.co
DB_PORT=5432

# --- Oracle Object Storage (S3-Compatible) ---
# Set to True to use OCI for heavy files and backups
USE_S3=False
AWS_S3_ACCESS_KEY_ID=your_oci_s3_access_key
AWS_S3_SECRET_ACCESS_KEY=your_oci_s3_secret_key
AWS_S3_BUCKET_NAME=your_ems_bucket_name
AWS_S3_ENDPOINT_URL=https://your_namespace.compat.objectstorage.your_region.oraclecloud.com
AWS_S3_REGION_NAME=your_region_name (e.g., us-ashburn-1)

# --- Payments (Paystack / Flutterwave) ---
# Get these from your Paystack/Flutterwave dashboard
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-...
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
FLUTTERWAVE_ENCRYPTION_KEY=...

# --- Email (Brevo / SMTP) ---
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_brevo_api_key
DEFAULT_FROM_EMAIL=your_verified_sender@example.com

# --- Celery & Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Set to True only for rapid development testing without Redis
CELERY_TASK_ALWAYS_EAGER=False

# --- Security & Auth ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-domain.com
IP_WHITELIST_ENABLED=False
IP_WHITELIST=127.0.0.1,::1
